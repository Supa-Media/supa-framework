{
  "name": "@supa-media/notifications",
  "version": "0.2.0",
  "description": "Push notification infrastructure for Supa apps — provider, hooks, and handlers for Expo + Convex",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "default": "./dist/providers/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./handlers": {
      "types": "./dist/handlers/index.d.ts",
      "default": "./dist/handlers/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "expo-constants": ">=18.0.0",
    "expo-device": ">=8.0.0",
    "expo-notifications": ">=0.32.0",
    "expo-router": ">=6.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.81.0"
  },
  "peerDependenciesMeta": {
    "expo-notifications": {
      "optional": true
    },
    "expo-device": {
      "optional": true
    },
    "expo-constants": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "@types/react": "~19.1.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "expo-constants": "~18.0.12",
    "expo-device": "~8.0.10",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.14"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Supa-Media/supa-framework.git",
    "directory": "packages/notifications"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "license": "MIT"
}
