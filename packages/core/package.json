{
  "name": "@supa-media/core",
  "version": "0.2.0",
  "description": "Runtime core for the Supa framework — providers, hooks, and navigation for Convex + Expo apps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "default": "./dist/providers/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./navigation": {
      "types": "./dist/navigation/index.d.ts",
      "default": "./dist/navigation/index.js"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "default": "./dist/forms/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@convex-dev/auth": ">=0.0.90",
    "@react-native-community/netinfo": ">=11.4.0",
    "@react-navigation/bottom-tabs": ">=7.0.0",
    "convex": ">=1.31.0",
    "expo": ">=54.0.0",
    "expo-secure-store": ">=15.0.0",
    "expo-updates": ">=29.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.81.0",
    "react-native-keyboard-controller": ">=1.20.0",
    "react-native-safe-area-context": ">=5.6.0"
  },
  "peerDependenciesMeta": {
    "expo-updates": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    },
    "@react-native-community/netinfo": {
      "optional": true
    },
    "react-native-keyboard-controller": {
      "optional": true
    },
    "@react-navigation/bottom-tabs": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "@types/react": "~19.1.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "expo": "~54.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-updates": "^29.0.15",
    "@convex-dev/auth": "^0.0.90",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "react-native-keyboard-controller": "^1.20.2",
    "react-native-safe-area-context": "~5.6.0",
    "convex": "^1.31.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Supa-Media/supa-framework.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "license": "MIT"
}
