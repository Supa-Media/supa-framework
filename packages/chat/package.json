{
  "name": "@supa-media/chat",
  "version": "1.0.1",
  "description": "Production-grade real-time messaging for Supa apps — paginated message lists, offline caching, and optimistic sends",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./stores": {
      "types": "./dist/stores/index.d.ts",
      "default": "./dist/stores/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "default": "./dist/adapters/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "tsc && node --test \"__tests__/*.test.js\""
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.81.0",
    "convex": ">=1.31.0",
    "zustand": ">=5.0.0",
    "@react-native-async-storage/async-storage": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "convex": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "@types/react": "~19.1.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "convex": "^1.31.3",
    "zustand": "^5.0.2",
    "@react-native-async-storage/async-storage": "2.2.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Supa-Media/supa-framework.git",
    "directory": "packages/chat"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "license": "MIT"
}
