{
  "name": "@supa-media/payments",
  "version": "0.2.0",
  "description": "Stripe payment integration for Supa apps — hooks, components, and config for subscriptions and checkout",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "convex": ">=1.31.0",
    "react": ">=19.0.0",
    "react-native": ">=0.81.0",
    "@stripe/stripe-react-native": ">=0.35.0"
  },
  "peerDependenciesMeta": {
    "@stripe/stripe-react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "@types/react": "~19.1.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "convex": "^1.31.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Supa-Media/supa-framework.git",
    "directory": "packages/payments"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "license": "MIT"
}
