{
  "name": "@supa-media/dev-assistant",
  "version": "2.0.0",
  "description": "\"App improves itself\" control plane for Convex apps — an AI-driven contribution pipeline (spec → build → review → merge → deploy) with a signed Routine callback, a monotonic status machine, and policy auto-merge. Ported from Togather's devAssistant (ADR-029).",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "templates"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "tsc -p tsconfig.typecheck.json && node --import ./test/register.mjs --test test/*.test.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./pipeline": "./src/pipeline/index.ts",
    "./functions/bugs": "./src/functions/bugs.ts",
    "./functions/actions": "./src/functions/actions.ts",
    "./functions/contributions": "./src/functions/contributions.ts",
    "./functions/maintainers": "./src/functions/maintainers.ts"
  },
  "peerDependencies": {
    "convex": ">=1.31.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Supa-Media/supa-framework.git",
    "directory": "packages/dev-assistant"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "5.9.3"
  }
}
